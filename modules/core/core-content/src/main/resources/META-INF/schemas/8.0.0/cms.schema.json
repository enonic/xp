{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://json-schema.enonic.com/8.0.0/cms.schema.json",
  "type": "object",
  "properties": {
    "mixin": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mixinMapping"
      }
    },
    "form": {
      "$ref": "https://json-schema.enonic.com/8.0.0/form/form.schema.json"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "mixinMapping": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "allowContentTypes": {
          "type": "string"
        },
        "optional": {
          "type": "boolean"
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    }
  }
}
