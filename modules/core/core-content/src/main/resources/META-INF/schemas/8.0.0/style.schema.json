{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://json-schema.enonic.com/8.0.0/style.schema.json",
  "type": "object",
  "properties": {
    "css": {
      "type": "string"
    },
    "image": {
      "type": "array",
      "items": {
        "type": "object",
        "displayName": {
          "$ref": "https://json-schema.enonic.com/8.0.0/core/localized-text.schema.json"
        },
        "aspectRatio": {
          "type": "string"
        },
        "filter": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "regions"
  ]
}
