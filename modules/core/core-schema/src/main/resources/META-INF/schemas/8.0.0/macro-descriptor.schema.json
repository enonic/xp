{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://json-schema.enonic.com/8.0.0/macro-descriptor.schema.json",
  "$defs": {
    "allowed-items": {
      "$dynamicAnchor": "form-items",
      "oneOf": [
        {
          "$ref": "https://json-schema.enonic.com/8.0.0/form/field-set.schema.json"
        },
        {
          "$ref": "https://json-schema.enonic.com/8.0.0/form/inputs.schema.json"
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "properties": {
    "mode": {
      "type": "string"
    },
    "form": {
      "$ref": "https://json-schema.enonic.com/8.0.0/form/form.schema.json"
    }
  }
}
