{
  "$base": "inputBaseDef",
  "properties": {
    "type": {
      "const": "CustomSelector"
    },
    "service": {
      "type": "string"
    },
    "extension": {
      "type": "string"
    },
    "params": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "galleryMode": {
      "type": "boolean"
    },
    "default": {
      "type": "string"
    }
  },
  "oneOf": [
    {
      "required": [
        "service"
      ],
      "not": {
        "required": [
          "extension"
        ]
      }
    },
    {
      "required": [
        "extension"
      ],
      "not": {
        "required": [
          "service"
        ]
      }
    }
  ]
}
