{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://json-schema.enonic.com/@schemaVersion@/task.schema.json",
  "type": "object",
  "properties": {
    "description": {
      "type": "string"
    },
    "form": {
      "$ref": "#/$defs/formDef"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inputsDef": {},
    "fieldSetDef": {},
    "itemSetDef": {},
    "optionSetDef": {},
    "formItemsDef": {
      "oneOf": [
        {
          "$ref": "#/$defs/inputsDef"
        },
        {
          "$ref": "#/$defs/fieldSetDef"
        },
        {
          "$ref": "#/$defs/itemSetDef"
        },
        {
          "$ref": "#/$defs/optionSetDef"
        }
      ],
      "unevaluatedProperties": false
    },
    "formDef": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/formItemsDef"
      },
      "additionalProperties": false
    }
  }
}
