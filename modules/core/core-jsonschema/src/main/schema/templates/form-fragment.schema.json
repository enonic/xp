{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "@schemaBaseUrl@/@schemaVersion@/form-fragment.schema.json",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string",
      "const": "FormFragment"
    },
    "displayName": {
      "$ref": "#/$defs/localizedTextDef"
    },
    "description": {
      "$ref": "#/$defs/localizedTextDef"
    },
    "form": {
      "$ref": "#/$defs/formDef"
    }
  },
  "required": [
    "kind"
  ],
  "additionalProperties": false,
  "$defs": {
    "localizedTextDef": {},
    "inputsDef": {},
    "fieldSetDef": {},
    "formFragmentDef": {},
    "itemSetDef": {},
    "optionSetDef": {},
    "formItemsDef": {
      "oneOf": [
        {
          "$ref": "#/$defs/inputsDef"
        },
        {
          "$ref": "#/$defs/fieldSetDef"
        },
        {
          "$ref": "#/$defs/formFragmentDef"
        },
        {
          "$ref": "#/$defs/itemSetDef"
        },
        {
          "$ref": "#/$defs/optionSetDef"
        }
      ]
    },
    "formDef": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/formItemsDef"
      },
      "additionalProperties": false
    }
  }
}
