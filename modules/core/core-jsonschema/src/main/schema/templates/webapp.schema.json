{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "@id@",
  "$defs": {
    "localizedTextDef": {},
    "genericValueDef": {}
  },
  "description": "YAML descriptor for Enonic XP Webapps.\nhttps://developer.enonic.com/docs/code/stable/webapps",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string",
      "const": "WebApp"
    },
    "description": {
      "$ref": "#/$defs/localizedTextDef"
    },
    "apis": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "config": {
      "$ref": "#/$defs/genericValueDef"
    }
  },
  "required": [
    "kind"
  ],
  "additionalProperties": false
}
