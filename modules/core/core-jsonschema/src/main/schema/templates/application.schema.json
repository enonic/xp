{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "@schemaBaseUrl@/@schemaVersion@/application.schema.json",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string",
      "const": "Application"
    },
    "title": {
      "$ref": "#/$defs/localizedTextDef"
    },
    "description": {
      "$ref": "#/$defs/localizedTextDef"
    },
    "vendorName": {
      "type": "string"
    },
    "vendorUrl": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "config": {
      "$ref": "#/$defs/genericValueDef"
    }
  },
  "required": [
    "kind"
  ],
  "additionalProperties": false,
  "$defs": {
    "localizedTextDef": {},
    "genericValueDef": {}
  }
}
