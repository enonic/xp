{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "@id@",
  "$defs": {
    "localizedTextDef": {},
    "genericValueDef": {},
    "inputsDef": {},
    "fieldSetDef": {},
    "itemSetDef": {},
    "optionSetDef": {},
    "formItemsDef": {
      "oneOf": [
        {
          "$ref": "#/$defs/inputsDef"
        },
        {
          "$ref": "#/$defs/fieldSetDef"
        },
        {
          "$ref": "#/$defs/itemSetDef"
        },
        {
          "$ref": "#/$defs/optionSetDef"
        }
      ]
    },
    "formDef": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/formItemsDef"
      },
      "additionalProperties": false
    }
  },
  "description": "YAML descriptor for Enonic XP ID Providers.\nhttps://developer.enonic.com/docs/code/stable/http/id-providers",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string",
      "const": "IdProvider"
    },
    "mode": {
      "type": "string",
      "enum": [
        "LOCAL",
        "EXTERNAL",
        "MIXED"
      ]
    },
    "form": {
      "$ref": "#/$defs/formDef"
    },
    "config": {
      "$ref": "#/$defs/genericValueDef"
    }
  },
  "additionalProperties": false,
  "required": [
    "kind"
  ]
}
